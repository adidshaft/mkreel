{
  "name": "mkreel",
  "version": "0.1.1",
  "description": "Creator-grade CLI for clipping YouTube videos into polished reels.",
  "license": "MIT",
  "keywords": [
    "youtube",
    "video",
    "clip",
    "reels",
    "shorts",
    "captions",
    "subtitles",
    "ffmpeg",
    "yt-dlp",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adidshaft/mkreel.git"
  },
  "homepage": "https://github.com/adidshaft/mkreel#readme",
  "bugs": {
    "url": "https://github.com/adidshaft/mkreel/issues"
  },
  "type": "module",
  "bin": {
    "mkreel": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "8.4.1",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "3.1.0",
    "fs-extra": "11.3.4",
    "ora": "9.3.0",
    "sanitize-filename": "1.6.4",
    "which": "6.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.5.2",
    "@types/which": "3.0.4",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  }
}
